rules_version = '2';

// Craft rules based on data consumption and protection needs
// Service: firebase.storage

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read access to all images
      allow read: if true;
      
      // Allow write access only to authenticated users (admins)
      // Note: You can further restrict this to specific admin emails if needed
      allow write: if request.auth != null;
    }
  }
}
